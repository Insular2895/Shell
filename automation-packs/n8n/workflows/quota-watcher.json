{
  "name": "quota-watcher",
  "nodes": [
    {
      "parameters": {"rule": {"interval": [{"field": "hours"}]}},
      "name": "Cron hourly",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [200, 300]
    },
    {
      "parameters": {
        "url": "={{ $env.FACTORY_API_URL }}/api/quotas/all",
        "method": "GET",
        "authentication": "headerAuth",
        "headerAuth": {"name": "Authorization", "value": "Bearer {{ $env.FACTORY_ADMIN_TOKEN }}"}
      },
      "name": "Fetch quotas",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [400, 300]
    },
    {
      "parameters": {
        "functionCode": "for (const item of items) {\n  for (const q of item.json.quotas || []) {\n    if (q.usage_pct >= 95) item.json.alert_level = 'P0';\n    else if (q.usage_pct >= 85) item.json.alert_level = 'P1';\n    else if (q.usage_pct >= 75) item.json.alert_level = 'P2';\n    else item.json.alert_level = null;\n  }\n}\nreturn items.filter(i => i.json.alert_level);"
      },
      "name": "Compute alerts",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [600, 300]
    }
  ],
  "connections": {
    "Cron hourly": {"main": [[{"node": "Fetch quotas", "type": "main", "index": 0}]]},
    "Fetch quotas": {"main": [[{"node": "Compute alerts", "type": "main", "index": 0}]]}
  },
  "active": false,
  "settings": {"executionOrder": "v1"},
  "versionId": "0.1.0",
  "meta": {"factory_status": "spec_export"}
}
