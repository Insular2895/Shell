{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ui-components extracted (cleanroom)",
  "type": "object",
  "properties": {
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["category", "purpose"],
        "properties": {
          "category": { "enum": ["dropzone", "form", "list", "card", "table", "chart", "modal", "navbar", "footer", "hero", "cta-button", "preview"] },
          "purpose": { "type": "string" },
          "approximate_position": { "type": "string", "description": "ex: 'top-center', 'sidebar' — abstrait, pas pixel" },
          "interactivity": { "enum": ["static", "input", "submit", "navigate"] }
        }
      }
    }
  }
}
