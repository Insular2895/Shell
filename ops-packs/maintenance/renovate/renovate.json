{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":automergeMinor",
    ":prHourlyLimit2"
  ],
  "schedule": ["before 4am on monday"],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Group security patches",
      "matchUpdateTypes": ["patch"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "description": "Major bumps : pin and require review",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "review-required"]
    },
    {
      "description": "Critical libraries : never automerge",
      "matchPackageNames": [
        "next",
        "react",
        "react-dom",
        "@supabase/ssr",
        "@supabase/supabase-js",
        "stripe",
        "ajv"
      ],
      "automerge": false,
      "labels": ["dependencies", "critical-lib", "review-required"]
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 4am on the first day of the month"]
  }
}
