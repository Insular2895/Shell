{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "service-catalog entry",
  "description": "Schéma d'un fichier ops/services/<site>.yml. Cf ops/services/document-extractor.yml comme exemple.",
  "type": "object",
  "required": ["site_id", "name", "repo", "stack", "finance", "status", "security"],
  "properties": {
    "site_id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "name": { "type": "string" },
    "repo": { "type": "string" },
    "production_url": { "type": "string", "format": "uri" },
    "staging_url": { "type": "string", "format": "uri" },
    "stack": {
      "type": "object",
      "properties": {
        "frontend": { "type": "string" },
        "backend": { "type": "string" },
        "jobs": { "type": "string" },
        "analytics": { "type": "string" },
        "errors": { "type": "string" },
        "uptime": { "type": "string" }
      }
    },
    "finance": {
      "type": "object",
      "required": ["monthly_budget_eur"],
      "properties": {
        "revenue_sources": { "type": "array" },
        "cost_sources": { "type": "array" },
        "monthly_budget_eur": { "type": "number" }
      }
    },
    "status": {
      "type": "object",
      "properties": {
        "default_mode": { "enum": ["normal", "degraded", "maintenance"] },
        "fallback_enabled": { "type": "boolean" },
        "maintenance_page": { "type": "boolean" }
      }
    },
    "security": {
      "type": "object",
      "properties": {
        "scans": { "type": "array" },
        "presidio_before_ai": { "type": "boolean" }
      }
    },
    "data": {
      "type": "object",
      "properties": {
        "growth_data_layer": { "type": "boolean" },
        "consent_required": { "type": "boolean" },
        "sellable_data_marts": { "type": "boolean" }
      }
    }
  }
}
