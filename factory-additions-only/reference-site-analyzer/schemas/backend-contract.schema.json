{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "backend-contract inferred from public site behavior",
  "type": "object",
  "properties": {
    "endpoints_inferred": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "method": { "type": "string" },
          "purpose": { "type": "string" },
          "estimated_latency_ms": { "type": "integer" },
          "long_running": { "type": "boolean" }
        }
      }
    },
    "auth_pattern": { "enum": ["none", "session", "jwt", "api_key", "unknown"] },
    "long_jobs_detected": { "type": "boolean" },
    "external_apis_likely": { "type": "array", "items": { "type": "string" } }
  }
}
