{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "worker-contract",
  "type": "object",
  "required": ["name", "trigger", "input_schema", "output_schema"],
  "properties": {
    "name": { "type": "string" },
    "trigger": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "enum": ["job_queue", "cron", "webhook", "event"] },
        "queue_name": { "type": "string" },
        "cron_expression": { "type": "string" }
      }
    },
    "input_schema": { "type": "object" },
    "output_schema": { "type": "object" },
    "lease_seconds": { "type": "integer" },
    "max_attempts": { "type": "integer" },
    "retry_strategy": { "enum": ["exponential_backoff", "fixed_delay", "no_retry"] },
    "timeout_seconds": { "type": "integer" },
    "fallback_action": { "type": "string" },
    "external_calls": {
      "type": "array",
      "items": { "type": "object" }
    }
  }
}
