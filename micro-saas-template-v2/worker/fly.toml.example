# =============================================================================
# fly.toml — déploiement worker sur Fly Machines
#
# Particularité : on configure auto_stop_machines=true et min_machines_running=0
# Le worker scale à 0 quand inactif (cron Vercel a basculé en mock-mode), ce
# qui réduit le coût à 0€/mois pendant les périodes sans utilisateurs.
#
# Setup initial :
#   fly launch --no-deploy --copy-config --name worker-monproduit
#   fly secrets set SHELL_URL=https://app.tonproduit.com
#   fly secrets set WORKER_API_TOKEN=xxx
#   fly secrets set OPENAI_API_KEY=sk-...   # si engine en a besoin
#   fly deploy
# =============================================================================

app = "worker-CHANGE_ME"  # à remplacer par produit
primary_region = "cdg"     # Paris CDG, change selon ton cas

[build]
  dockerfile = "worker/Dockerfile"
  ignorefile = "worker/.dockerignore"

[env]
  PYTHONUNBUFFERED = "1"
  LEASE_SECONDS = "900"
  POLL_INTERVAL_SECONDS = "5"

[[vm]]
  size = "shared-cpu-1x"
  memory = "512mb"

# Auto-scale : 0 machines quand pas de boulot.
# Le Shell reste up sur Vercel, mais le worker s'arrête → coût ~0€.
# Le Shell réveille un nouveau worker au premier job en pending.
[deploy]
  strategy = "rolling"

[[services]]
  protocol = "tcp"
  internal_port = 8080  # Pas utilisé (worker poll, pas serveur), mais Fly veut un port

  [services.concurrency]
    type = "connections"
    hard_limit = 1
    soft_limit = 1

[checks]
  [checks.health]
    type = "http"
    interval = "60s"
    timeout = "10s"
    grace_period = "30s"
    method = "get"
    path = "/health"
    port = 8080

# Sleep agressif quand pas d'activité — économie cash
[machine]
  auto_stop_machines = true
  auto_start_machines = true
  min_machines_running = 0
