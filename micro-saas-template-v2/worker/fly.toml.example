# =============================================================================
# fly.toml — déploiement worker sur Fly Machines
#
# Particularité : ce worker n'expose pas de service HTTP public.
# Il est démarré/arrêté par le Shell via la Fly Machines API :
#   - Stripe actif/trialing -> site_config.engine_mode='live' + start Machine
#   - aucun client payant   -> site_config.engine_mode='mock' + stop Machine
#
# Le process s'arrête aussi tout seul après EXIT_WHEN_IDLE_SECONDS sans job.
# Avec restart=on-failure, une sortie propre laisse la Machine stoppée.
#
# Setup initial :
#   cd micro-saas-template-v2
#   cp worker/fly.toml.example fly.toml
#   # édite app = "worker-..."
#   fly launch --no-deploy --copy-config --name worker-monproduit
#   fly secrets set SHELL_URL=https://app.tonproduit.com
#   fly secrets set WORKER_API_TOKEN=xxx
#   fly secrets set OPENAI_API_KEY=sk-...   # si engine en a besoin
#   fly secrets set SHELL_SERVICE_TOKEN=xxx # si l'engine upload vers Shell
#   fly deploy
#
# Côté Vercel, configurer ensuite :
#   WORKER_PROVIDER=fly
#   FLY_APP_NAME=worker-monproduit
#   FLY_API_TOKEN=<token Fly scoped>
#   FLY_MACHINE_ID=<optionnel, si tu veux cibler une Machine précise>
# =============================================================================

app = "worker-CHANGE_ME"  # à remplacer par produit
primary_region = "cdg"     # Paris CDG, change selon ton cas

[build]
  dockerfile = "worker/Dockerfile"
  ignorefile = "worker/.dockerignore"

[env]
  PYTHONUNBUFFERED = "1"
  LEASE_SECONDS = "900"
  POLL_INTERVAL_SECONDS = "5"
  EXIT_WHEN_IDLE_SECONDS = "600"

[[vm]]
  size = "shared-cpu-1x"
  memory = "512mb"

[deploy]
  strategy = "rolling"

[[restart]]
  policy = "on-failure"
  retries = 3
  processes = ["app"]
