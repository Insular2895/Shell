# ============================================================================
# .env.example  (v2)
# Copie ce fichier en .env.local (jamais commité).
# ============================================================================

# ----- Supabase -------------------------------------------------------------
# Trouvable dans : Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co

# Supabase est en transition : utilise PUBLISHABLE_KEY (nouveau nom) si dispo,
# sinon ANON_KEY (ancien nom). Les deux marchent.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...   # alternative

# ⚠️ SECRET ABSOLU — bypass RLS. Jamais côté client. Webhooks + API upload only.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ----- Stripe ---------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Trouvable dans : Stripe Dashboard → Developers → Webhooks → ton endpoint
# Pour le dev local : `stripe listen --forward-to localhost:3000/api/stripe/webhook`
STRIPE_WEBHOOK_SECRET=whsec_...

# ----- App ------------------------------------------------------------------
# URL publique de l'app (utilisée pour les emails de confirmation, redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- Worker lifecycle -----------------------------------------------------
# Par défaut, aucun worker externe ne tourne : site_config.engine_mode='mock'
# et les démos utilisent engine/output.example.json. Coût engine = 0.
#
# Quand un client payant arrive, passe WORKER_PROVIDER=fly côté Vercel.
# Le webhook Stripe et le cron /api/cron/auto-degrade démarrent/arrêtent alors
# les Machines Fly selon les abonnements actifs.
WORKER_PROVIDER=none

# Provider Fly Machines (server-side only, jamais côté client).
# Crée le token via Fly Dashboard/CLI, avec scope limité au worker app.
# FLY_API_HOSTNAME peut rester vide : défaut https://api.machines.dev
FLY_APP_NAME=
FLY_API_TOKEN=
FLY_MACHINE_ID=
FLY_API_HOSTNAME=
WORKER_PROVIDER_TIMEOUT_MS=5000

# Token partagé entre le Shell (Vercel) et le worker externe (Fly).
# Le worker l'utilise pour appeler /api/jobs/worker/claim et /complete.
# Génère avec : openssl rand -hex 32
WORKER_API_TOKEN=

# ----- Crons (NOUVEAU v2) ---------------------------------------------------
# Token partagé pour authentifier les appels cron (Vercel Cron envoie ce
# secret en header). Génère avec : openssl rand -hex 32
CRON_SECRET=

# ----- Auto-degrade / billing gate -----------------------------------------
# Le cron vérifie la source de vérité Stripe/Supabase :
# - aucun abonnement active/trialing payant => engine_mode='mock' + stop worker
# - au moins un abonnement active/trialing payant => engine_mode='live' + start worker
AUTO_DEGRADE_ENABLED=1

# ----- Engine runtime -------------------------------------------------------
# Note v2 : ce mode est appliqué côté worker. Le Shell respecte aussi
# site_config.engine_mode (table) qui prime sur cette variable d'env.
#
# 'mock'    : retourne output.example.json après 1.5s (front-only, pas d'engine)
# 'docker'  : docker run sur la machine ou un worker (dev local, ou Fly Machines)
# 'http'    : POST vers un service distant déjà déployé (Fly.io, Railway, Modal)
ENGINE_MODE=mock

# Si ENGINE_MODE=docker
ENGINE_IMAGE=ghcr.io/<user>/<product>-engine:latest

# Si ENGINE_MODE=http
ENGINE_URL=https://engine.example.com/run
ENGINE_TOKEN=

# Token interne pour les callbacks engine→Shell (uploads de fichiers)
# Génère avec : openssl rand -hex 32
SHELL_SERVICE_TOKEN=

# URL interne du Shell vue par l'engine (Docker dev = host.docker.internal)
SHELL_INTERNAL_URL=http://host.docker.internal:3000

# ----- Upload security ------------------------------------------------------
# Limites hard appliquées par /api/upload avant écriture Supabase Storage.
MAX_USER_UPLOAD_BYTES=10485760
MAX_ENGINE_UPLOAD_BYTES=26214400
ALLOWED_UPLOAD_MIME_TYPES=application/pdf,text/plain,text/csv,image/png,image/jpeg,image/webp

# ----- LLM (lus par l'engine, déclarés dans engine/manifest.yaml.env) ------
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
